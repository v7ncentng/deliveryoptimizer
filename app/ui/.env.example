# Copy to .env.local and fill in your values (get key + Map ID from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
# DELIVERYOPTIMIZER_API_URL=  # Cloud Run URL — only needed in production (leave unset for local dev)

# Feedback reporting
# FEEDBACK_ENABLED=1
# FEEDBACK_GITHUB_REPO=benevolentbandwidth/delivery-optimizer
# FEEDBACK_GITHUB_APP_ID=
# FEEDBACK_GITHUB_INSTALLATION_ID=
# FEEDBACK_GITHUB_PRIVATE_KEY=
# FEEDBACK_SCREENSHOT_BUCKET=
# NEXT_PUBLIC_FEEDBACK_RECAPTCHA_SITE_KEY=
# FEEDBACK_RECAPTCHA_SECRET=
# FEEDBACK_RECAPTCHA_MIN_SCORE=0.5
# FEEDBACK_RATE_LIMIT_WINDOW_MS=600000
# FEEDBACK_RATE_LIMIT_MAX=5
# FEEDBACK_DAILY_SHUTDOWN_THRESHOLD=100
