# Copy to .env.local and fill in your values (get key + Map ID from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
# DELIVERYOPTIMIZER_API_URL=  # Cloud Run URL — only needed in production (leave unset for local dev)
# WHATSAPP_API_TOKEN=  # Reserved for a future real WhatsApp Cloud API integration — not implemented yet; Send Routes always uses the mock sender regardless of this value
# WHATSAPP_PHONE_NUMBER_ID=  # Reserved for a future real WhatsApp Cloud API integration — not implemented yet; Send Routes always uses the mock sender regardless of this value
# WHATSAPP_MOCK_LATENCY_MS=600  # optional: override simulated send delay in mock mode
