DELIVERYOPTIMIZER_JOB_LEASE_MS=90000
DELIVERYOPTIMIZER_JOB_RESULT_TTL_SECONDS=86400
DELIVERYOPTIMIZER_JOB_WORKER_HEALTH_MS=5000
POSTGRES_DB=deliveryoptimizer
POSTGRES_USER=deliveryoptimizer
